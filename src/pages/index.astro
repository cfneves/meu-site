<!-- ══ HERO ══ -->
<section id="hero" style="padding:110px 0 80px;position:relative;overflow:hidden;min-height:100vh;display:flex;align-items:center;">

  <div style="position:absolute;top:12%;left:6%;width:520px;height:520px;background:radial-gradient(circle,rgba(242,200,17,0.055),transparent 70%);border-radius:50%;filter:blur(72px);animation:blob-float 9s ease-in-out infinite;pointer-events:none;"></div>
  <div style="position:absolute;bottom:8%;right:5%;width:440px;height:440px;background:radial-gradient(circle,rgba(45,212,191,0.055),transparent 70%);border-radius:50%;filter:blur(72px);animation:blob-float 11s ease-in-out infinite;animation-delay:-5s;pointer-events:none;"></div>
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent 0%,var(--pbi) 35%,var(--teal) 65%,transparent 100%);opacity:0.28;"></div>

  <div class="wrap" style="width:100%;">
    <div class="hero-grid" style="display:grid;grid-template-columns:1fr 460px;gap:80px;align-items:center;">

      <div>
        <div class="chip"><span class="chip-dot"></span>Power BI · Governança de Dados · Inteligência Artificial</div>

        <h1 class="h1">
          Dados que revelam<br/>
          o que os números<br/>
          <em>escondem.</em>
