<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cláudio Ferreira Neves · Especialista Power BI, Dados e IA para Empresas</title>
  <meta name="description" content="Especialista em Power BI, Governança de Dados e IA. Dashboards executivos, indicadores estratégicos e automação de relatórios para empresas." />
  <meta name="keywords" content="Power BI, especialista Power BI, Business Intelligence, governança de dados, BI, indicadores estratégicos" />
  <meta name="author" content="Cláudio Ferreira Neves" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://claudioneves.com.br/" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Cláudio Ferreira Neves · Power BI, Dados e IA para Empresas" />
  <meta property="og:description" content="Dados estruturados, decisões estratégicas. Power BI + Governança de Dados + IA." />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Plus+Jakarta+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #112d4e;
      --bg-2:       #1a3d6b;
      --bg-3:       #1e4678;
      --glass:      rgba(255,255,255,0.028);
      --glass-2:    rgba(255,255,255,0.055);
      --border:     rgba(255,255,255,0.07);
      --border-2:   rgba(255,255,255,0.13);
      --text:       #EFF3FF;
      --text-2:     #7685A2;
      --text-3:     #3A4E6A;
      --pbi:        #F2C811;
      --pbi-dim:    rgba(242,200,17,0.07);
      --pbi-border: rgba(242,200,17,0.22);
      --pbi-glow:   rgba(242,200,17,0.16);
      --teal:       #2DD4BF;
      --teal-dim:   rgba(45,212,191,0.07);
      --font-h:     'Space Grotesk', system-ui, sans-serif;
      --font-b:     'Plus Jakarta Sans', system-ui, sans-serif;
      --r:          14px;
    }

    html {
      background-color: var(--bg);
      background-image: radial-gradient(circle, rgba(255,255,255,0.022) 1px, transparent 1px);
      background-size: 28px 28px;
      color: var(--text);
      scroll-behavior: smooth;
    }
    body  { font-family: var(--font-b); overflow-x: hidden; line-height: 1.55; }
    section { scroll-margin-top: 60px; }
    a { text-decoration: none; }

    /* ── NAV ── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 60px; display: flex; align-items: center;
      transition: background 0.4s, border-color 0.4s;
      border-bottom: 1px solid transparent;
    }
    .nav.scrolled {
      background: rgba(17,45,78,0.95);
      backdrop-filter: blur(24px) saturate(1.2);
      border-bottom-color: var(--border);
    }
    .nav-inner {
      max-width: 1280px; margin: 0 auto; padding: 0 40px;
      width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 20px;
    }
    .nav-links { display: flex; gap: 28px; align-items: center; }
    .nav-link {
      font-family: var(--font-h); font-size: 0.78rem; font-weight: 500;
      color: var(--text-2); transition: color 0.2s; letter-spacing: 0.01em;
      position: relative;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
      height: 1px; background: var(--pbi); transform: scaleX(0); transition: transform 0.22s;
    }
    .nav-link:hover { color: var(--text); }
    .nav-link:hover::after { transform: scaleX(1); }
    .nav-icon {
      width: 30px; height: 30px; border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
      transition: opacity 0.2s, transform 0.2s;
    }
    .nav-icon:hover { opacity: 0.75; transform: translateY(-1px); }

    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 6px; background: none; border: none; color: var(--text);
    }
    .hamburger span { width: 22px; height: 2px; background: currentColor; border-radius: 2px; transition: all 0.3s; display: block; }
    .mobile-menu {
      position: fixed; top: 60px; left: 0; right: 0; z-index: 99;
      background: rgba(4,13,27,0.98); backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border);
      padding: 20px 40px; display: none; flex-direction: column; gap: 16px;
    }
    .mobile-menu.open { display: flex; }

    /* ── BUTTONS ── */
    .btn {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: var(--font-h); font-size: 0.83rem; font-weight: 600;
      border-radius: 100px; padding: 11px 22px; transition: all 0.22s;
      cursor: pointer; border: none; white-space: nowrap; letter-spacing: 0.01em;
    }
    .btn-pbi  { background: var(--pbi); color: #000; box-shadow: 0 2px 12px rgba(242,200,17,0.22); }
    .btn-pbi:hover  { background: #ffd534; transform: translateY(-2px); box-shadow: 0 8px 28px var(--pbi-glow); }
    .btn-ghost { background: transparent; color: var(--pbi); border: 1px solid var(--pbi-border); }
    .btn-ghost:hover { background: var(--pbi-dim); border-color: var(--pbi); }

    /* ── CHIP ── */
    .chip {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 4px 14px; border-radius: 100px;
      background: var(--pbi-dim); border: 1px solid var(--pbi-border);
      font-family: var(--font-h); font-size: 0.6rem; font-weight: 600;
      color: var(--pbi); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 22px;
    }
    .chip-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--pbi); flex-shrink: 0; box-shadow: 0 0 8px var(--pbi); animation: pulse 2s infinite; }

    /* ── SECTION LABEL ── */
    .sec-label {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: var(--font-h); font-size: 0.64rem; font-weight: 600;
      color: var(--text-2); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 16px;
    }
    .sec-label::before {
      content: ''; width: 18px; height: 2px;
      background: var(--pbi); border-radius: 1px; flex-shrink: 0;
    }

    /* ── TYPOGRAPHY ── */
    .h1 {
      font-family: var(--font-h); font-size: clamp(2.6rem, 5vw, 5.2rem);
      font-weight: 700; line-height: 1.08; letter-spacing: -1.5px; color: var(--text); margin-bottom: 20px;
    }
    .h1 em {
      font-style: normal;
      background: linear-gradient(118deg, var(--pbi) 0%, #e8a000 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .h2 {
      font-family: var(--font-h); font-size: clamp(1.7rem, 2.6vw, 2.45rem);
      font-weight: 700; line-height: 1.14; letter-spacing: -0.8px; color: var(--text); margin-bottom: 12px;
    }
    .h2 em { font-style: normal; color: var(--pbi); }
    .h3 { font-family: var(--font-h); font-size: 0.94rem; font-weight: 600; color: var(--text); margin-bottom: 8px; }

    /* ── CARD ── */
    .card {
      background: var(--glass); border: 1px solid var(--border); border-radius: var(--r); padding: 24px;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
      backdrop-filter: blur(14px); position: relative; overflow: hidden;
    }
    .card::after {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent 0%, var(--pbi-border) 50%, transparent 100%);
      opacity: 0; transition: opacity 0.3s;
    }
    .card:hover { border-color: var(--pbi-border); transform: translateY(-3px); box-shadow: 0 16px 44px rgba(0,0,0,0.45); }
    .card:hover::after { opacity: 1; }

    /* ── LAYOUT ── */
    .wrap { max-width: 1280px; margin: 0 auto; padding: 0 40px; }
    .sec  { padding: 88px 0; }
    .sec-alt { background: rgba(0,0,0,0.22); border-top: 1px solid var(--border); }

    /* ── DOMINO ── */
    .domino-wrap { position: relative; height: 420px; }
    .dp {
      position: absolute; width: 92%; background: rgba(5,11,24,0.96);
      border: 1px solid rgba(255,255,255,0.08); border-radius: 13px; padding: 18px 20px; overflow: hidden;
      backdrop-filter: blur(20px);
    }
    .dp::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(--pbi),var(--teal)); }
    .dp-back  { top:32px; left:48px; transform:rotate(5.5deg); opacity:0.22; box-shadow:0 24px 60px rgba(0,0,0,0.7); z-index:1; }
    .dp-mid   { top:16px; left:24px; transform:rotate(2.5deg); opacity:0.50; box-shadow:0 28px 64px rgba(0,0,0,0.6); z-index:2; }
    .dp-front { top:0; left:0; opacity:1; box-shadow:0 36px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06); z-index:3; animation:dp-float 6s ease-in-out infinite; }
    .dp-bar   { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.06); }
    .dp-title { font-family:var(--font-h); font-size:0.58rem; font-weight:600; color:rgba(255,255,255,0.32); letter-spacing:0.1em; text-transform:uppercase; }
    .dp-dots  { display:flex; gap:4px; }
    .dp-dot   { width:7px; height:7px; border-radius:50%; }
    .dp-kpis  { display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-bottom:12px; }
    .dp-kpi   { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:6px; padding:8px 10px; }
    .dp-kl    { font-size:0.48rem; color:rgba(255,255,255,0.28); text-transform:uppercase; letter-spacing:0.07em; margin-bottom:4px; }
    .dp-kv    { font-family:var(--font-h); font-size:0.95rem; font-weight:700; line-height:1; }
    .dp-kd    { font-size:0.5rem; font-weight:600; margin-top:3px; }
    .dp-chart { display:flex; align-items:flex-end; gap:4px; height:58px; }
    .dp-b     { flex:1; border-radius:2px 2px 0 0; }

    /* ── CLIENT LOGO — cartão branco sobre cinza-claro ── */
    .client-logo {
      display: flex; align-items: center; justify-content: center;
      padding: 14px 22px;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      height: 76px; min-width: 120px; max-width: 168px;
      transition: all 0.22s;
    }
    .client-logo:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 18px rgba(0,0,0,0.12);
      border-color: #F2C811;
    }
    .client-logo img { max-height: 42px; max-width: 110px; object-fit: contain; opacity: 0.8; transition: opacity 0.22s; }
    .client-logo:hover img { opacity: 1; }

    /* ── PROCESS STEPS ── */
    .process-grid {
      display: grid; grid-template-columns: repeat(5,1fr); gap: 10px;
    }
    .process-card {
      background: var(--glass); border: 1px solid var(--border); border-radius: var(--r);
      padding: 22px 18px; position: relative; transition: border-color 0.3s, transform 0.3s;
    }
    .process-card:hover { border-color: var(--pbi-border); transform: translateY(-3px); }
    .process-card::after {
      content: attr(data-arrow); position: absolute; top: 50%; right: -16px; transform: translateY(-50%);
      font-family: var(--font-h); font-size: 0.65rem; color: var(--text-3); z-index: 1;
    }
    .process-card:last-child::after { display: none; }
    .process-num {
      font-family: var(--font-h); font-size: 2.2rem; font-weight: 700;
      color: rgba(242,200,17,0.12); line-height: 1; margin-bottom: 12px;
    }
    .process-icon {
      width: 36px; height: 36px; border-radius: 9px; background: var(--pbi-dim);
      border: 1px solid var(--pbi-border); display: flex; align-items: center;
      justify-content: center; margin-bottom: 12px; color: var(--pbi);
    }
    .process-title { font-family: var(--font-h); font-size: 0.82rem; font-weight: 600; color: var(--text); margin-bottom: 6px; }
    .process-desc  { font-size: 0.75rem; color: var(--text-2); line-height: 1.65; }

    /* ── PORTFOLIO CARD ── */
    .pcard {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden;
      transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
    }
    .pcard:hover { transform: translateY(-4px); border-color: var(--pbi-border); box-shadow: 0 20px 50px rgba(0,0,0,0.55); }
    .pcard-header { height: 160px; background: rgba(4,10,22,0.98); position: relative; overflow: hidden; }
    .pcard-header::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(--pbi),var(--teal)); z-index:2; }
    .pcard-body { padding: 18px 20px; }

    /* ── CONTACT CARD ── */
    .contact-card {
      display: flex; align-items: center; gap: 14px;
      padding: 18px 20px; background: var(--bg-2);
      border: 1px solid var(--border); border-radius: var(--r);
      transition: all 0.25s;
    }
    .contact-card:hover { border-color: var(--pbi-border); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.35); }

    /* ── SKILL BAR ── */
    .skill-track { height: 5px; background: rgba(255,255,255,0.05); border-radius: 100px; overflow: hidden; }
    .skill-fill  { height: 100%; width: 0; border-radius: 100px; transition: width 1.2s cubic-bezier(0.4,0,0.2,1); }

    /* ── FOOTER NAV HOVER ── */
    .footer-link { font-family: var(--font-h); font-size: 0.72rem; font-weight: 500; color: var(--text-3); transition: color 0.2s; }
    .footer-link:hover { color: var(--pbi); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
      .hero-grid    { grid-template-columns: 1fr !important; }
      .domino-wrap  { display: none !important; }
      .srv-grid     { grid-template-columns: 1fr !important; }
      .process-grid { grid-template-columns: repeat(3,1fr) !important; }
    }
    @media (max-width: 768px) {
      .portfolio-grid { grid-template-columns: 1fr !important; }
      .contact-grid   { grid-template-columns: 1fr !important; }
      .about-grid     { grid-template-columns: 1fr !important; }
      .process-grid   { grid-template-columns: repeat(2,1fr) !important; }
    }
    @media (max-width: 600px) {
      .h1 { font-size: 2.4rem; letter-spacing: -0.8px; }
      .h2 { font-size: 1.7rem; }
      .nav-links   { display: none !important; }
      .nav-actions { display: none !important; }
      .hamburger   { display: flex !important; }
      .hero-cta    { flex-direction: column; align-items: flex-start !important; }
      .wrap { padding: 0 20px; }
      .sec  { padding: 64px 0; }
      .process-grid { grid-template-columns: 1fr !important; }
      .process-card::after { display: none; }
    }

    @keyframes pulse      { 0%,100%{opacity:1} 50%{opacity:.3} }
    @keyframes dp-float   { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @keyframes blob-float { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-24px) scale(1.04)} }
  </style>
</head>
